generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusEntityType {
  project
  task
  client
}

enum FinancialValueType {
  income
  expense
  planned_income
  planned_expense
}

enum ReportType {
  projects
  tasks
  finance
  clients
  summary
}

enum AuditAction {
  create
  update
  delete
  login
  import
  export
}

enum CrmLeadLifecycleStatus {
  active
  converted
  failed
  deleted
}

enum CrmActivityStatus {
  pending
  completed
  canceled
  unknown
}

enum MessengerProvider {
  telegram
}

enum WorkerStatus {
  active
  paused
  archived
}

enum DailyPlanStatus {
  draft
  sent
  completed
  missed
}

enum DailyReportStatus {
  pending
  submitted
  missed
}

enum ReportItemStatus {
  planned
  in_progress
  done
  blocked
  postponed
}

enum IntegrationProvider {
  bitrix24
  telegram
}

enum SyncJobStatus {
  queued
  running
  succeeded
  failed
}

enum IntegrationEventDirection {
  inbound
  outbound
}

enum IntegrationEventStatus {
  received
  processed
  failed
  ignored
}

enum OutboundCommandType {
  bitrix_add_timeline_comment
  bitrix_add_activity
  bitrix_complete_activity
  bitrix_update_lead_stage
  telegram_send_message
}

enum OutboundCommandStatus {
  queued
  sent
  succeeded
  failed
  canceled
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id              String           @id @default(cuid())
  fullName        String
  email           String           @unique
  passwordHash    String
  roleId          String
  departmentId    String?
  isActive        Boolean          @default(true)
  role            Role             @relation(fields: [roleId], references: [id])
  responsibleFor  Project[]        @relation("ProjectResponsible")
  tasks           Task[]           @relation("TaskResponsible")
  financialValues FinancialValue[] @relation("FinancialValueCreator")
  reports         Report[]         @relation("ReportCreator")
  auditLogs       AuditLog[]
  externalWorkers ExternalWorker[]
  syncJobs        SyncJob[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Client {
  id            String    @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?   @unique
  source        String?
  status        String?
  crmLeadId     String?
  projects      Project[]
  crmLead       CrmLead?  @relation(fields: [crmLeadId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([crmLeadId])
}

model Direction {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Status {
  id       String           @id @default(cuid())
  entityType StatusEntityType
  code     String
  name     String
  color    String?
  isFinal  Boolean          @default(false)
  sortOrder Int             @default(0)
  projects Project[]
  tasks    Task[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([entityType, code])
}

model Project {
  id                String           @id @default(cuid())
  name              String
  clientId          String
  crmLeadId         String?
  responsibleUserId String
  directionId       String
  statusId          String
  startDate         DateTime
  plannedEndDate    DateTime?
  actualEndDate     DateTime?
  budget            Decimal          @db.Decimal(14, 2)
  description       String?
  client            Client           @relation(fields: [clientId], references: [id])
  crmLead           CrmLead?         @relation(fields: [crmLeadId], references: [id])
  responsibleUser   User             @relation("ProjectResponsible", fields: [responsibleUserId], references: [id])
  direction         Direction        @relation(fields: [directionId], references: [id])
  status            Status           @relation(fields: [statusId], references: [id])
  tasks             Task[]
  financialValues   FinancialValue[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([crmLeadId])
}

model Task {
  id                String    @id @default(cuid())
  projectId         String
  crmLeadId         String?
  title             String
  description       String?
  responsibleUserId String
  statusId          String
  priority          String
  plannedEndDate    DateTime?
  actualEndDate     DateTime?
  laborHours        Decimal?  @db.Decimal(8, 2)
  project           Project   @relation(fields: [projectId], references: [id])
  crmLead           CrmLead?  @relation(fields: [crmLeadId], references: [id])
  responsibleUser   User      @relation("TaskResponsible", fields: [responsibleUserId], references: [id])
  status            Status    @relation(fields: [statusId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([crmLeadId])
}

model ReportPeriod {
  id              String           @id @default(cuid())
  name            String
  dateFrom        DateTime
  dateTo          DateTime
  isClosed        Boolean          @default(false)
  financialValues FinancialValue[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model FinancialValue {
  id          String             @id @default(cuid())
  projectId   String
  periodId    String
  type        FinancialValueType
  amount      Decimal            @db.Decimal(14, 2)
  comment     String?
  date        DateTime
  createdById String
  project     Project            @relation(fields: [projectId], references: [id])
  period      ReportPeriod       @relation(fields: [periodId], references: [id])
  createdBy   User               @relation("FinancialValueCreator", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Report {
  id          String     @id @default(cuid())
  title       String
  description String?
  type        ReportType
  filters     Json
  createdById String
  createdBy   User       @relation("ReportCreator", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  user       User?       @relation(fields: [userId], references: [id])
  createdAt  DateTime    @default(now())
}

model CrmStage {
  id               String    @id @default(cuid())
  externalId       String    @unique
  entityId         String    @default("STATUS")
  name             String
  sortOrder        Int       @default(0)
  color            String?
  semantic         String?
  rawPayload       Json?
  leads            CrmLead[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastSyncedAt     DateTime?
}

model CrmLead {
  id                    String                 @id @default(cuid())
  externalId            String                 @unique
  title                 String
  stageExternalId       String?
  lifecycleStatus       CrmLeadLifecycleStatus @default(active)
  amount                Decimal?               @db.Decimal(14, 2)
  currency              String?
  source                String?
  assignedByExternalId  String?
  assignedByName        String?
  contactName           String?
  contactPhone          String?
  contactEmail          String?
  comments              String?
  customerPath          String?
  lossReason            String?
  bitrixCreatedAt       DateTime?
  bitrixUpdatedAt       DateTime?
  lastSyncedAt          DateTime?
  deletedAt             DateTime?
  rawPayload            Json?
  stage                 CrmStage?              @relation(fields: [stageExternalId], references: [externalId])
  clients               Client[]
  projects              Project[]
  tasks                 Task[]
  activities            CrmActivity[]
  dailyPlanItems        WorkerDailyPlanItem[]
  reportItems           WorkerReportItem[]
  outboundCommands      OutboundCommand[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([stageExternalId])
  @@index([assignedByExternalId])
  @@index([bitrixUpdatedAt])
}

model CrmActivity {
  id                    String            @id @default(cuid())
  externalId            String            @unique
  leadExternalId        String?
  ownerTypeId           Int?
  typeId                Int?
  subject               String
  description           String?
  deadline              DateTime?
  startTime             DateTime?
  endTime               DateTime?
  status                CrmActivityStatus @default(unknown)
  bitrixStatus          String?
  completed             Boolean           @default(false)
  responsibleExternalId String?
  responsibleName       String?
  bitrixCreatedAt       DateTime?
  bitrixUpdatedAt       DateTime?
  lastSyncedAt          DateTime?
  rawPayload            Json?
  lead                  CrmLead?          @relation(fields: [leadExternalId], references: [externalId])
  dailyPlanItems        WorkerDailyPlanItem[]
  reportItems           WorkerReportItem[]
  outboundCommands      OutboundCommand[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([leadExternalId])
  @@index([deadline])
  @@index([responsibleExternalId])
}

model ExternalWorker {
  id                       String             @id @default(cuid())
  userId                   String?
  fullName                 String
  bitrixUserExternalId     String?
  timezone                 String             @default("Asia/Novosibirsk")
  workdayStart             String             @default("09:00")
  workdayEnd               String             @default("18:00")
  status                   WorkerStatus       @default(active)
  notes                    String?
  user                     User?              @relation(fields: [userId], references: [id])
  messengerAccounts        MessengerAccount[]
  dailyPlans               WorkerDailyPlan[]
  dailyReports             WorkerDailyReport[]
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([bitrixUserExternalId])
}

model MessengerAccount {
  id                 String            @id @default(cuid())
  workerId           String
  provider           MessengerProvider @default(telegram)
  externalUserId     String?
  externalChatId     String?
  username           String?
  displayName        String?
  isVerified         Boolean           @default(false)
  verifiedAt         DateTime?
  lastInboundAt      DateTime?
  rawPayload         Json?
  worker             ExternalWorker    @relation(fields: [workerId], references: [id])
  messageDeliveries  MessageDelivery[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([provider, externalChatId])
  @@index([workerId])
}

model WorkerDailyPlan {
  id              String                @id @default(cuid())
  workerId        String
  workDate        DateTime
  status          DailyPlanStatus       @default(draft)
  generatedAt     DateTime              @default(now())
  sentAt          DateTime?
  summary         String?
  worker          ExternalWorker        @relation(fields: [workerId], references: [id])
  items           WorkerDailyPlanItem[]
  dailyReports    WorkerDailyReport[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([workerId, workDate])
}

model WorkerDailyPlanItem {
  id                  String           @id @default(cuid())
  planId              String
  leadId              String?
  activityId          String?
  status              ReportItemStatus @default(planned)
  title               String
  dueAt               DateTime?
  sortOrder           Int              @default(0)
  plan                WorkerDailyPlan  @relation(fields: [planId], references: [id])
  lead                CrmLead?         @relation(fields: [leadId], references: [id])
  activity            CrmActivity?     @relation(fields: [activityId], references: [id])
  reportItems         WorkerReportItem[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([planId])
}

model WorkerDailyReport {
  id            String             @id @default(cuid())
  workerId      String
  planId        String?
  workDate      DateTime
  status        DailyReportStatus  @default(pending)
  submittedAt   DateTime?
  summary       String?
  rawPayload    Json?
  worker        ExternalWorker     @relation(fields: [workerId], references: [id])
  plan          WorkerDailyPlan?   @relation(fields: [planId], references: [id])
  items         WorkerReportItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([workerId, workDate])
}

model WorkerReportItem {
  id              String              @id @default(cuid())
  reportId        String
  planItemId      String?
  leadId          String?
  activityId      String?
  status          ReportItemStatus
  comment         String?
  needsManager    Boolean             @default(false)
  nextActionAt    DateTime?
  report          WorkerDailyReport   @relation(fields: [reportId], references: [id])
  planItem        WorkerDailyPlanItem? @relation(fields: [planItemId], references: [id])
  lead            CrmLead?            @relation(fields: [leadId], references: [id])
  activity        CrmActivity?        @relation(fields: [activityId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([reportId])
}

model MessageDelivery {
  id                 String             @id @default(cuid())
  messengerAccountId String?
  provider           MessengerProvider  @default(telegram)
  externalMessageId  String?
  recipientChatId    String?
  text               String
  payload            Json?
  status             OutboundCommandStatus @default(queued)
  attempts           Int                @default(0)
  nextAttemptAt      DateTime?
  sentAt             DateTime?
  errorMessage       String?
  messengerAccount   MessengerAccount?  @relation(fields: [messengerAccountId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status, nextAttemptAt])
}

model BotConversationState {
  id             String            @id @default(cuid())
  provider       MessengerProvider @default(telegram)
  externalChatId String
  state          String
  context        Json?
  expiresAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([provider, externalChatId])
}

model IntegrationConnection {
  id                String              @id @default(cuid())
  provider          IntegrationProvider
  name              String
  baseUrl           String?
  isEnabled         Boolean             @default(false)
  settings          Json?
  lastCheckedAt     DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([provider, name])
}

model SyncJob {
  id              String              @id @default(cuid())
  provider        IntegrationProvider
  jobType         String
  status          SyncJobStatus       @default(queued)
  startedAt       DateTime?
  finishedAt      DateTime?
  requestedById   String?
  cursor          String?
  stats           Json?
  errorMessage    String?
  requestedBy     User?               @relation(fields: [requestedById], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([provider, jobType, status])
}

model IntegrationEvent {
  id              String                    @id @default(cuid())
  provider        IntegrationProvider
  direction       IntegrationEventDirection
  eventType       String
  externalId      String?
  idempotencyKey  String?                   @unique
  status          IntegrationEventStatus    @default(received)
  payload         Json?
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([provider, eventType])
  @@index([status, createdAt])
}

model OutboundCommand {
  id             String                @id @default(cuid())
  provider       IntegrationProvider
  commandType    OutboundCommandType
  status         OutboundCommandStatus @default(queued)
  idempotencyKey String                @unique
  leadId         String?
  activityId     String?
  payload        Json
  response       Json?
  attempts       Int                   @default(0)
  nextAttemptAt  DateTime?
  sentAt         DateTime?
  errorMessage   String?
  lead           CrmLead?              @relation(fields: [leadId], references: [id])
  activity       CrmActivity?          @relation(fields: [activityId], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([provider, status, nextAttemptAt])
}
